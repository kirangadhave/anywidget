{
  "plugins": ["typescript", "import"],
  "ignorePatterns": ["packages/deno", "packages/signals"],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "import/no-unassigned-import": [
      "error",
      { "allow": ["**/*.css", "**/*.scss", "@docsearch/css"] }
    ],
    "no-shadow": "off"
  }
}
